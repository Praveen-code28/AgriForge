DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agriforge
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
MODEL_PATH=checkpoints/agriforge_crop_health_v1.pth
UPLOAD_DIR=uploads
OPENWEATHER_API_KEY=your_openweather_api_key_here
MAX_UPLOAD_SIZE_MB=10
KNOWLEDGE_BASE_PATH=ml/weather/knowledge

# LLM (optional). If unset, reports use the deterministic fallback synthesis.
# For OpenAI-compatible endpoints (NVIDIA NIM, GLM, vLLM) keep the raw model id
# here; the app prefixes it with "openai/" automatically when LLM_BASE_URL is set.
LLM_PROVIDER=nvidia
LLM_MODEL=z-ai/glm-5.2
LLM_API_KEY=
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_TIMEOUT_SECONDS=45
LLM_MAX_TOKENS=900
